<script>
// === DATA ===
const IMG = 'https://images.unsplash.com/photo-1541643600914-53b81b6c4f6d?w=600&q=80';
const IMG_FALLBACK = 'https://images.pexels.com/photos/1961795/pexels-photo-1961795.jpeg?auto=compress&w=600';

const perfumes = [
  { id:'first-kiss', name:'First Kiss', tagline:'Floral · Fresh', price:'₹1,299', priceNum:1299,
    desc:"Bright, playful, and a little shy — jasmine and citrus over soft white musk. For the moment you're just getting to know someone.",
    notes:['Jasmine','Citrus','White Musk'],
    filter:'hue-rotate(340deg) saturate(1.3) brightness(1.05)',
    accent:'#f4a8b8', gradFrom:'#3a0015', gradVia:'#1a0008' },
  { id:'midnight-kiss', name:'Midnight Kiss', tagline:'Oud · Sensual', price:'₹1,799', priceNum:1799,
    desc:'Dark oud, smoked amber, a whisper of rose. Built for the hours after the lights go down.',
    notes:['Dark Oud','Smoked Amber','Rose'],
    filter:'hue-rotate(220deg) saturate(1.6) brightness(0.55) contrast(1.2)',
    accent:'#7ba8e8', gradFrom:'#060a1a', gradVia:'#020408' },
  { id:'velvet-kiss', name:'Velvet Kiss', tagline:'Gourmand · Warm', price:'₹1,599', priceNum:1599,
    desc:'Rose petals dipped in vanilla and warm sandalwood. Soft, addictive, impossible to ignore.',
    notes:['Rose','Vanilla','Sandalwood'],
    filter:'hue-rotate(295deg) saturate(1.5) brightness(0.85) contrast(1.1)',
    accent:'#d4709a', gradFrom:'#2a0818', gradVia:'#100308' },
  { id:'wild-kiss', name:'Wild Kiss', tagline:'Fruity · Energetic', price:'₹1,299', priceNum:1299,
    desc:"Blackberry, pink pepper, and a burst of yuzu. Loud, fun, made for the girl who's always moving.",
    notes:['Blackberry','Pink Pepper','Yuzu'],
    filter:'hue-rotate(250deg) saturate(1.8) brightness(0.78) contrast(1.15)',
    accent:'#b07ad4', gradFrom:'#140a28', gradVia:'#080310' },
  { id:'forever-kiss', name:'Forever Kiss', tagline:'Signature · Luxury', price:'₹2,199', priceNum:2199,
    desc:'Our flagship blend — iris, oud, and golden amber layered for a scent that lasts from morning meetings to midnight.',
    notes:['Iris','Oud','Golden Amber'],
    filter:'hue-rotate(35deg) saturate(1.4) brightness(1.05) contrast(1.05)',
    accent:'#c9a96e', gradFrom:'#1a1408', gradVia:'#0a0800' },
];

const WA_BASE = 'https://wa.me/919355236004?text=';
const CALL = 'tel:+919355236004';

function waLink(name) {
  if (name) return WA_BASE + encodeURIComponent("Hi Kissology! I'd like to order " + name + " (50ml). Please share payment & delivery details.");
  return WA_BASE + encodeURIComponent("Hi Kissology! I'd like to order a perfume. Can you help me choose?");
}

function imgWithFallback(src, filter) {
  return '<img src="' + src + '" alt="Kissology" style="filter:' + filter + '" onerror="this.src=\'' + IMG_FALLBACK + '\';this.onerror=null">';
}

// === HERO SLIDESHOW ===
let activeSlide = 0;
function buildHero() {
  const bg = document.getElementById('heroBg');
  let html = '';
  perfumes.forEach(function(p, i) {
    html += '<div style="position:absolute;inset:0;opacity:' + (i === 0 ? '1' : '0') + ';transition:opacity 1s" id="heroSlide' + i + '">' +
            '<img src="' + IMG + '" alt="" style="width:100%;height:100%;object-fit:cover;filter:' + p.filter + ';opacity:0.18" onerror="this.src=\'' + IMG_FALLBACK + '\'">' +
            '</div>';
  });
  html += '<div class="overlay"></div>';
  bg.innerHTML = html;

  const dots = document.getElementById('heroDots');
  let dotsHtml = '';
  perfumes.forEach(function(_, i) {
    dotsHtml += '<button class="' + (i === 0 ? 'active' : '') + '" onclick="setSlide(' + i + ')"></button>';
  });
  dots.innerHTML = dotsHtml;

  setInterval(function() {
    setSlide((activeSlide + 1) % perfumes.length);
  }, 3000);
}

function setSlide(i) {
  activeSlide = i;
  perfumes.forEach(function(_, j) {
    const el = document.getElementById('heroSlide' + j);
    if (el) el.style.opacity = j === i ? '1' : '0';
  });
  document.querySelectorAll('.hero-dots button').forEach(function(d, j) {
    d.classList.toggle('active', j === i);
    d.style.width = j === i ? '20px' : '6px';
  });
}

// === TICKER ===
function buildTicker() {
  const items = ['Small Batch Perfumery','Five Signature Moods','Made In India','Ships Pan India','Order via WhatsApp','Real Replies Guaranteed'];
  let html = '';
  for (let r = 0; r < 2; r++) {
    html += '<div style="display:flex">';
    items.forEach(function(t) {
      html += '<span class="ticker-item"><span class="dot"></span>' + t + '</span>';
    });
    html += '</div>';
  }
  document.getElementById('tickerTrack').innerHTML = html;
}

// === COLLECTIONS ===
function buildCollections() {
  const grid = document.getElementById('collectionsGrid');
  let html = '';
  perfumes.forEach(function(p, i) {
    html += '<div class="perfume-card" id="card' + i + '">' +
      '<div class="perfume-img-wrap">' +
        imgWithFallback(IMG, p.filter) +
        '<div class="perfume-img-grad" style="background:linear-gradient(to top,' + p.gradFrom + ' 0%,transparent 50%)"></div>' +
        '<span class="perfume-badge">' + p.tagline + '</span>' +
        '<span class="perfume-price-badge" style="color:' + p.accent + '">' + p.price + '</span>' +
      '</div>' +
      '<div class="perfume-body">' +
        '<p class="perfume-label">Kissology</p>' +
        '<h3 class="perfume-name">' + p.name + '</h3>' +
        '<p class="perfume-desc">' + p.desc + '</p>' +
        '<div class="perfume-notes">' + p.notes.map(function(n){return '<span>'+n+'</span>'}).join('') + '</div>' +
        '<div class="perfume-actions">' +
          '<button class="btn-order" style="background:' + p.accent + '" onclick="openModal(' + i + ')">' +
            '<svg class="icon" viewBox="0 0 24 24" style="width:13px;height:13px;"><path d="M12 2L2 7v10l10 5 10-5V7L12 2zm0 2.2L19.5 8 12 11.8 4.5 8 12 4.2zM4 9.5l7 3.5v7.8l-7-3.5V9.5zm9 11.3V13l7-3.5v7.8l-7 3.5z"/></svg>' +
            'Order Now' +
          '</button>' +
          '<a class="btn-wa" href="' + waLink(p.name) + '" target="_blank" rel="noopener">' +
            '<svg class="icon" viewBox="0 0 24 24" style="width:13px;height:13px;"><path d="M12 2C6.5 2 2 6.5 2 12c0 1.8.5 3.5 1.3 5L2 22l5.2-1.4c1.4.8 3.1 1.2 4.8 1.2 5.5 0 10-4.5 10-10S17.5 2 12 2z"/></svg>' +
            'WhatsApp' +
          '</a>' +
        '</div>' +
      '</div>' +
    '</div>';
  });
  grid.innerHTML = html;

  // Intersection observer for fade-in
  const obs = new IntersectionObserver(function(entries) {
    entries.forEach(function(e, idx) {
      if (e.isIntersecting) {
        const card = e.target;
        const i = parseInt(card.id.replace('card',''));
        setTimeout(function() { card.classList.add('visible'); }, i * 90);
        obs.unobserve(card);
      }
    });
  }, { threshold: 0.1 });
  document.querySelectorAll('.perfume-card').forEach(function(c) { obs.observe(c); });
}

// === QUICK ORDER ===
function buildQuickOrder() {
  const grid = document.getElementById('quickGrid');
  let html = '';
  perfumes.forEach(function(p, i) {
    html += '<button class="quick-item" onclick="openModal(' + i + ')">' +
      '<div class="qi-thumb">' + imgWithFallback(IMG, p.filter) + '</div>' +
      '<div class="qi-info"><div class="qi-name">' + p.name + '</div><div class="qi-tag">' + p.tagline + '</div></div>' +
      '<div class="qi-price"><div class="p">' + p.price + '</div><div class="s">50ml</div></div>' +
    '</button>';
  });
  grid.innerHTML = html;
}

// === MODAL ===
let modalQty = 1;
let modalPerfume = null;

function openModal(i) {
  modalPerfume = perfumes[i];
  modalQty = 1;
  document.body.style.overflow = 'hidden';
  renderModal();
  document.getElementById('modal').style.display = 'flex';
}

function closeModal() {
  document.getElementById('modal').style.display = 'none';
  document.body.style.overflow = '';
}

function changeQty(delta) {
  modalQty = Math.max(1, modalQty + delta);
  renderModal();
}

function renderModal() {
  const p = modalPerfume;
  const total = (p.priceNum * modalQty).toLocaleString('en-IN');
  const waText = encodeURIComponent("Hi Kissology! I'd like to order " + modalQty + "x " + p.name + " (50ml) — Total: ₹" + total + ". Please share payment & delivery details.");

  document.getElementById('modalCard').innerHTML =
    '<div class="modal-header" style="background:linear-gradient(135deg,' + p.gradFrom + ',' + p.gradVia + ')">' +
      '<button class="modal-close" onclick="closeModal()">&times;</button>' +
      '<div class="modal-header-inner">' +
        '<div class="modal-thumb">' + imgWithFallback(IMG, p.filter) + '</div>' +
        '<div>' +
          '<p class="modal-eyebrow" style="color:' + p.accent + '">Order</p>' +
          '<h3 class="modal-title">' + p.name + '</h3>' +
          '<p class="modal-sub">' + p.tagline + ' &middot; 50ml EDP</p>' +
        '</div>' +
      '</div>' +
    '</div>' +
    '<div class="modal-body">' +
      '<div><p class="modal-section-label">Key Notes</p>' +
        '<div class="modal-notes">' + p.notes.map(function(n){return '<span>'+n+'</span>'}).join('') + '</div>' +
      '</div>' +
      '<div class="modal-qty-row"><p class="modal-section-label" style="margin:0">Quantity</p>' +
        '<div class="modal-qty"><button onclick="changeQty(-1)">&minus;</button><span class="val">' + modalQty + '</span><button onclick="changeQty(1)">+</button></div>' +
      '</div>' +
      '<div class="modal-total-row"><p class="modal-total-label">Total</p><p class="modal-total-val" style="color:' + p.accent + '">₹' + total + '</p></div>' +
      '<a class="modal-cta-wa" href="' + WA_BASE + waText + '" target="_blank" rel="noopener">' +
        '<svg class="icon" viewBox="0 0 24 24" style="width:16px;height:16px;"><path d="M12 2C6.5 2 2 6.5 2 12c0 1.8.5 3.5 1.3 5L2 22l5.2-1.4c1.4.8 3.1 1.2 4.8 1.2 5.5 0 10-4.5 10-10S17.5 2 12 2z"/></svg>' +
        'Order on WhatsApp' +
      '</a>' +
      '<a class="modal-cta-call" href="' + CALL + '">' +
        '<svg class="icon" viewBox="0 0 24 24" style="width:16px;height:16px;"><path d="M6.6 10.8c1.4 2.8 3.8 5.1 6.6 6.6l2.2-2.2c.3-.3.7-.4 1-.2 1.1.4 2.3.6 3.6.6.6 0 1 .4 1 1V20c0 .6-.4 1-1 1-9.4 0-17-7.6-17-17 0-.6.4-1 1-1h3.5c.6 0 1 .4 1 1 0 1.2.2 2.4.6 3.6.1.4 0 .8-.3 1l-2.2 2.2z"/></svg>' +
        'Call to Order' +
      '</a>' +
    '</div>';
}

// === UTILITIES ===
function scrollTo(id) {
  document.getElementById(id).scrollIntoView({ behavior: 'smooth' });
}

function toggleMenu() {
  document.getElementById('mobileMenu').classList.toggle('hidden');
}

// === INIT ===
document.addEventListener('DOMContentLoaded', function() {
  buildHero();
  buildTicker();
  buildCollections();
  buildQuickOrder();

  setTimeout(function() {
    document.getElementById('heroContent').classList.add('visible');
  }, 150);
});
</script>
</body>
</html>
